import React, { useEffect, useState } from "react";
import { 
  Settings, 
  HelpCircle, 
  Terminal, 
  Calendar, 
  Link as LinkIcon, 
  AlertTriangle, 
  Copy, 
  Check, 
  Info,
  ChevronRight,
  Disc,
  ArrowUpRight
} from "lucide-react";
import { Language, DocsSection, EventTab, ImageMethod } from "../types";
import { navigateTo } from "../utils/routing";

interface DocsProps {
  currentLang: Language;
  currentHash: string;
}

export default function Docs({ currentLang, currentHash }: DocsProps) {
  // Extract active section from the hash, fallback to "setup"
  const getSectionFromHash = (hash: string): DocsSection => {
    const section = hash.replace("#", "") as DocsSection;
    const validSections: DocsSection[] = ["setup", "how-it-works", "commands", "events", "links"];
    return validSections.includes(section) ? section : "setup";
  };

  const [activeSection, setActiveSection] = useState<DocsSection>(getSectionFromHash(currentHash));
  const [activeEventTab, setActiveEventTab] = useState<EventTab>("logo");
  const [activeImageMethod, setActiveImageMethod] = useState<ImageMethod>("github");
  const [copiedText, setCopiedText] = useState<string | null>(null);

  // Sync hash changes
  useEffect(() => {
    setActiveSection(getSectionFromHash(currentHash));
  }, [currentHash]);

  const handleSidebarClick = (section: DocsSection, e: React.MouseEvent) => {
    e.preventDefault();
    navigateTo("docs", currentLang, `#${section}`);
  };

  const copyToClipboard = (text: string) => {
    navigator.clipboard.writeText(text);
    setCopiedText(text);
    setTimeout(() => setCopiedText(null), 2000);
  };

  // Translations
  const text = {
    en: {
      sidebar: {
        setup: "Setup",
        howItWorks: "How It Works",
        commands: "Commands",
        addEvent: "Add an Event",
        imageLinks: "Image Links",
      },
      setup: {
        title: "Configuration (Setup)",
        intro: "Logoto is a specialized bot designed to automate changing your Discord server's icon, name, banner, and invite splash backgrounds without requiring complex setup structures or lines of code.",
        getStarted: "Getting Started",
        getStartedDesc: "To begin utilizing the bot to its full capacity, simply run the initial server deployment command:",
        setupCommandDesc: "The essential first command. Automatically builds the required category and logging channels (Logoto, log-logoto) for a quick launch.",
        noteTitle: "IMPORTANT NOTE:",
        noteDesc1: "The channel named ",
        noteDesc2: " must exist on your server to handle automatic operation diagnostics.",
        noteDesc3: "The bot uses this channel to post daily engineering logs (e.g. l-Loading, n-Loading, etc.). Note that these updates are only generated if an automated asset swap is actively scheduled for that specific date. If no event is registered, no text is sent. The /setup command configures this safely for you.",
      },
      howItWorks: {
        title: "General Workflow",
        intro: "Logoto autonomously scans for the presence of specific scheduled text channels inside your Discord server to index, stage, and execute your visual updates.",
        cronTitle: "Cron Schedule:",
        cronDesc: "All automated verifications and server adjustments apply systematically every day at exactly 00:00 UTC.",
        rulesTitle: "Priority Rules & Limitations",
        rulesDesc: "To preserve server stability and comply with standard Discord API rate limits, Logoto follows specific handling parameters:",
        rule1: "One alteration per asset type daily: The server name can change once per day, the server icon once, the banner once, and the invitation background splash once.",
        rule2: "Simultaneous edits: You can perfectly combine icon adjustments AND a server name update (or any other type) on the exact same calendar date. Both updates execute at 00:00 UTC.",
        rule3: "Duplicate channels (Visual Priority): If you accidentally build multiple channels for the same asset type on the same date (e.g., two l-25-12 channels containing different icons), the channel nested highest up in your Discord category list takes absolute priority and its asset will be applied.",
      },
      commands: {
        title: "Logoto Bot Commands",
        intro: "Explore the complete list of built-in features accessible straight out of the box using Discord's official Slash Commands:",
        cSetup: "The essential first command. Automatically builds the required category and logging channels (Logoto, log-logoto) for a quick launch.",
        cAddEvent: "Instantly creates a formatting-compliant text channel to schedule your future visual updates.",
        cHelp: "Displays the operational dashboard commands directory (or opens this index).",
        cInfo: "Returns technical data regarding the engine's real-time operational status and cluster health.",
        cPing: "Tests connection latency between the bot framework and Discord's internal API gateways.",
        cInvite: "Fetches the official authorization link to introduce Logoto to your own community servers.",
        cSupport: "Points to our central support server where you can request live technical assistance.",
      },
      events: {
        title: "Add an Event",
        intro: "Select a graphic or textual element below to display its detailed step-by-step scheduling implementation guide:",
        warningTitle: "ASSET LINK WARNING:",
        warningDesc: "Never copy direct image URLs straight out of a Discord text channel chat window (Discord CDN URLs). These internal addresses use temporary encryption hashes and will expire completely within 24 to 48 hours. If the link breaks before your scheduled date arrives, Logoto will fail to load the image. Refer to the Image Links section to resolve this.",
        tabs: {
          logo: {
            title: "Server Icon",
            short: "Automate your server profile picture update on a precise date.",
            h: "Automated Server Icon Setup",
            step1: "Create the Planning Channel: The text channel name must strictly follow this exact syntax: l-[DAY]-[MONTH] (or use /add-an-event). EXAMPLE: To schedule an icon update for Halloween (October 31st): l-31-10",
            step2: "Prepare your Graphic File: Obtain a permanent asset URL (via GitHub or ImgBB) that closes with a standard image file extension syntax (.png, .jpg, .jpeg, or .gif). Sizing guidelines: A perfectly square 512 × 512 pixel canvas layout.",
            step3: "Schedule the Update: Open the settings of the channel created in step 1, select the Channel Topic input box, and paste your permanent direct asset URL inside.",
            step4: "Execution: The bot processes the file and updates the server's icon at exactly 00:00 UTC on the chosen date. In case of channel duplication, the highest channel takes priority.",
          },
          name: {
            title: "Server Name",
            short: "Automatically adjust the displayed structural text title of your community.",
            h: "Automated Server Name Setup",
            step1: "Create the Planning Channel: The text channel name must strictly match this layout format: n-[DAY]-[MONTH] (or use /add-an-event). EXAMPLE: To adjust your server title on New Year's Day (January 1st): n-1-1",
            step2: "Schedule the Update: Open the properties of the designated channel. Type your complete new server text string directly into the Channel Topic text input area.",
            step3: "Execution: The bot updates the server title string at 00:00 UTC on the scheduled month and day.",
          },
          banner: {
            title: "Server Banner",
            short: "Schedule illustrations to slide above your channel lists (Boost Level 2+ Required).",
            h: "Automated Server Banner Setup",
            step1: "Create the Planning Channel: The text channel name must strictly match this layout format: b-[DAY]-[MONTH] (or use /add-an-event). EXAMPLE: To deploy a festive holiday banner on Christmas Day (December 25th): b-25-12",
            step2: "Prepare your Graphic File: Generate and copy a permanent direct web URL pointing to an external static image asset (.png, .jpg). Sizing guidelines: Standard sizing targets are 960 × 540 pixels (16:9 aspect ratio). Keep essential elements centered.",
            step3: "Schedule the Update: Paste this permanent direct image link into your channel's Channel Topic configuration box.",
            step4: "Execution: Logoto applies the graphic asset to your server banner at 00:00 UTC.",
          },
          invite: {
            title: "Invite Splash",
            short: "Personalize the backgrounds of your generic invite links (Boost Level 1+ Required).",
            h: "Automated Invite Splash Background Setup",
            step1: "Create the Planning Channel: The text channel name must strictly match this layout format: i-[DAY]-[MONTH] (or use /add-an-event). EXAMPLE: To schedule a themed background splash for July 14th: i-14-7",
            step2: "Prepare your Graphic File: Generate and copy a permanent direct web URL pointing to an external static image asset. Sizing guidelines: Sizing targets require a crisp 1920 × 1080 pixel footprint (standard 16:9 aspect ratio).",
            step3: "Schedule the Update: Paste your permanent direct image URL straight into the channel's Channel Topic input area.",
            step4: "Execution: As soon as the target day reaches 00:00 UTC, the illustration rolls out onto your web invite screens.",
          },
        },
      },
      links: {
        title: "Get a Permanent Image Link",
        intro: "For Logoto to properly retrieve and deploy your icons, banners, or splashes down the line, the provided URL destination must remain permanently online. Because direct Discord URLs break quickly, you must rely on a dedicated third-party asset hosting platform.",
        methodTitle: "Choose one of the recommended approaches below to generate a valid, permanent direct link:",
        github: {
          title: "GitHub (Recommended)",
          h: "Hosting via GitHub (Ultra-Stable)",
          step1: "Create a public repository: Go to GitHub, click New repository, name it, and make sure it is set to Public.",
          step2: "Important (If repo is empty): Check the box that says 'Add a README file' during creation. Why? If the repository is completely empty, GitHub hides the easy web interface upload tools and only shows raw Git code commands.",
          step3: "Upload your files: Head over to your active repository page, click the 'Add file' button near the top right, and select 'Upload files'. Drag and drop your graphics (icons, backgrounds...) and click the green 'Commit changes' button at the bottom to save.",
          step4: "Get the Raw direct URL: Click on your uploaded file inside your repository view to open it. Then, click the 'Raw' button located above the image display. The target URL should now start with raw.githubusercontent.com.",
          tipTitle: "Manual Raw URL Override Hint:",
          tipDesc: "If you cannot find the 'Raw' button element, grab the generic GitHub file page URL structure:",
          tipExample1: "https://github.com/username/repository/blob/main/image.png",
          tipDesc2: "And swap the leading address segments yourself to instantly output the true direct raw address:",
          tipExample2: "https://raw.githubusercontent.com/username/repository/main/image.png",
        },
        imgbb: {
          title: "ImgBB / Imgur",
          h: "Free Dedicated Image Hosts (ImgBB / Imgur)",
          step1: "Navigate to a dependable free image hosting utility such as ImgBB or Imgur.",
          step2: "Upload your graphics file onto their servers. Make sure to choose the option that keeps files permanently online without an automatic expiration date.",
          step3: "Once processing finishes, look under their embedded code link generation settings and select the 'Direct Link' option.",
          step4: "Double-check the generated URL structure: it must explicitly end with an image file extension suffix (e.g., .png, .jpg, .jpeg, or .gif). If it hits a blurred wrapper text extension instead, Logoto will fail to trace the asset.",
          step5: "Copy this direct link and enter it safely into your Discord planning channel topic.",
        },
      },
    },
    fr: {
      sidebar: {
        setup: "Setup",
        howItWorks: "Fonctionnement",
        commands: "Commandes",
        addEvent: "Ajouter un événement",
        imageLinks: "Liens d'images",
      },
      setup: {
        title: "Configuration (Setup)",
        intro: "Logoto est un bot spécialisé dans l'automatisation du changement de logo, de nom, de bannière et d'image d'invitation de votre serveur Discord, sans nécessiter de configurations ou de lignes de code complexes.",
        getStarted: "Premiers pas",
        getStartedDesc: "Pour commencer à utiliser le bot au maximum de ses capacités, lancez simplement la commande de configuration initiale :",
        setupCommandDesc: "Première commande à faire. Crée automatiquement la catégorie et les salons nécessaires (Logoto, log-logoto) pour un démarrage rapide.",
        noteTitle: "NOTE IMPORTANTE :",
        noteDesc1: "Le salon nommé ",
        noteDesc2: " doit impérativement exister sur votre serveur pour assurer le suivi technique.",
        noteDesc3: "Le bot utilise ce salon pour envoyer ses messages techniques quotidiens de chargement (l-Loading, n-Loading, b-Loading ou i-Loading). Attention, ces messages ne sont envoyés que si un changement est effectivement programmé le jour même. S'il n'y a aucun événement, aucun log n'est posté. La commande /setup s'occupe de créer ce salon proprement pour vous.",
      },
      howItWorks: {
        title: "Fonctionnement Général",
        intro: "Logoto surveille de manière autonome la présence de salons textuels spécifiques au sein de votre serveur Discord pour planifier et exécuter vos mises à jour esthétiques.",
        cronTitle: "Planification horaire :",
        cronDesc: "Toutes les mises à jour et vérifications automatiques configurées sur votre serveur s'exécutent chaque jour précisément à 00h00 UTC.",
        rulesTitle: "Règles de priorité et limites",
        rulesDesc: "Pour garantir la stabilité du serveur et respecter les quotas de l'API Discord, Logoto applique des règles strictes de gestion quotidienne :",
        rule1: "Un seul changement par type et par jour : Le nom du serveur peut changer une fois par jour, le logo une fois, la bannière une fois, et le fond d'invitation une fois.",
        rule2: "Modifications simultanées : Il est tout à fait possible de changer le logo ET le nom (ou tout autre élément) le même jour. Les deux actions s'exécuteront à 00h00 UTC.",
        rule3: "Gestion des doublons (Priorité visuelle) : Si vous avez créé par erreur plusieurs salons pour le même élément le même jour (par exemple deux salons l-25-12 avec des logos différents), c'est le salon situé le plus haut dans la liste de vos catégories Discord qui prime et qui sera appliqué par le bot.",
      },
      commands: {
        title: "Les Commandes du Bot Logoto",
        intro: "Découvrez la liste complète des commandes intégrées disponibles directement avec le système de Slash Commands de Discord :",
        cSetup: "Première commande à faire. Crée automatiquement la catégorie et les salons nécessaires (Logoto, log-logoto) pour un démarrage rapide.",
        cAddEvent: "Crée automatiquement un salon de planification au bon format pour vos événements futurs.",
        cHelp: "Affiche la liste des commandes du bot (ou cette page de documentation).",
        cInfo: "Renvoie toutes les informations utiles concernant l'état actuel et le statut du bot.",
        cPing: "Obtenez la latence en temps réel entre le bot et l'API Discord.",
