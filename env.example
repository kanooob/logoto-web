  }[currentLang];

  return (
    <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col md:flex-row gap-8">
      {/* Sidebar Navigation */}
      <aside className="w-full md:w-64 shrink-0 flex flex-col gap-2 bg-[#2f3136]/50 p-4 rounded-xl border border-white/5 h-fit md:sticky md:top-24">
        {(["setup", "how-it-works", "commands", "events", "links"] as DocsSection[]).map((section) => {
          const sidebarKeyMap: Record<DocsSection, keyof typeof text.sidebar> = {
            "setup": "setup",
            "how-it-works": "howItWorks",
            "commands": "commands",
            "events": "addEvent",
            "links": "imageLinks"
          };
          return (
            <a
              key={section}
              href={`#${section}`}
              onClick={(e) => handleSidebarClick(section, e)}
              className={`flex items-center justify-between px-4 py-3 rounded-lg text-sm font-bold tracking-wide transition-all duration-200 ${
                activeSection === section
                  ? "bg-[#8c935d] text-white shadow-md shadow-[#8c935d]/10"
                  : "text-white/60 hover:text-white hover:bg-white/5"
              }`}
            >
              <span className="capitalize">{text.sidebar[sidebarKeyMap[section]]}</span>
              <ChevronRight className={`w-4 h-4 transition-transform ${activeSection === section ? "translate-x-1" : "opacity-0"}`} />
            </a>
          );
        })}
      </aside>

      {/* Main Divider (Desktop only) */}
      <div className="hidden md:block w-px bg-white/10 self-stretch my-2" />

      {/* Main Content Area */}
      <main className="flex-1 bg-[#2f3136]/30 border border-white/5 p-6 sm:p-8 rounded-2xl animate-fadeIn">
        
        {/* Section: SETUP */}
        {activeSection === "setup" && (
          <div className="space-y-6">
            <div className="flex items-center gap-3 text-[#a3ab72]">
              <Settings className="w-8 h-8" />
              <h1 className="text-3xl font-extrabold tracking-tight">{text.setup.title}</h1>
            </div>
            <p className="text-white/80 leading-relaxed font-medium">{text.setup.intro}</p>
            
            <div className="border-t border-white/10 pt-6 space-y-4">
              <h2 className="text-xl font-bold text-white">{text.setup.getStarted}</h2>
              <p className="text-white/70 text-sm leading-relaxed">{text.setup.getStartedDesc}</p>
              
              {/* Copyable code block */}
              <div className="bg-[#3a3d42] rounded-xl p-4 flex items-center justify-between gap-4 border border-white/5 group relative overflow-hidden">
                <code className="font-mono text-sm font-bold text-white tracking-wide">/setup</code>
                <button
                  onClick={() => copyToClipboard("/setup")}
                  className="bg-[#2f3136] hover:bg-[#8c935d] text-white p-2 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-[#8c935d]"
                  title="Copy command"
                >
                  {copiedText === "/setup" ? <Check className="w-4 h-4 text-green-400" /> : <Copy className="w-4 h-4" />}
                </button>
              </div>
              <p className="text-white/60 text-sm italic font-medium">{text.setup.setupCommandDesc}</p>
            </div>

            {/* Note box */}
            <div className="bg-[#3c3a2e] border-l-4 border-[#8c935d] p-5 rounded-r-xl space-y-2 shadow-lg shadow-black/10">
              <div className="flex items-center gap-2 text-[#a3ab72]">
                <Info className="w-5 h-5" />
                <h3 className="font-bold tracking-wide">{text.setup.noteTitle}</h3>
              </div>
              <p className="text-sm text-white/90 leading-relaxed font-medium">
                {text.setup.noteDesc1}
                <code className="bg-[#484c52] px-1.5 py-0.5 rounded font-mono font-bold text-xs">log-logoto</code>
                {text.setup.noteDesc2}
              </p>
              <p className="text-xs text-white/70 leading-relaxed font-medium">
                {text.setup.noteDesc3}
              </p>
            </div>
          </div>
        )}

        {/* Section: HOW IT WORKS */}
        {activeSection === "how-it-works" && (
          <div className="space-y-6">
            <div className="flex items-center gap-3 text-[#a3ab72]">
              <HelpCircle className="w-8 h-8" />
              <h1 className="text-3xl font-extrabold tracking-tight">{text.howItWorks.title}</h1>
            </div>
            <p className="text-white/80 leading-relaxed font-medium">{text.howItWorks.intro}</p>

            <div className="bg-[#8c935d]/10 border-l-4 border-[#a3ab72] p-5 rounded-r-xl shadow-lg shadow-black/5">
              <h3 className="font-bold text-[#a3ab72] tracking-wide mb-1">{text.howItWorks.cronTitle}</h3>
              <p className="text-sm text-white/90 leading-relaxed font-medium">
                {text.howItWorks.cronDesc}
              </p>
            </div>

            <div className="border-t border-white/10 pt-6 space-y-4">
              <h2 className="text-xl font-bold text-white">{text.howItWorks.rulesTitle}</h2>
              <p className="text-white/70 text-sm leading-relaxed">{text.howItWorks.rulesDesc}</p>
              
              <ol className="list-decimal list-inside space-y-4 text-white/80 pl-2">
                <li className="text-sm leading-relaxed font-semibold pl-2">
                  <span className="text-white font-normal">{text.howItWorks.rule1}</span>
                </li>
                <li className="text-sm leading-relaxed font-semibold pl-2">
                  <span className="text-white font-normal">{text.howItWorks.rule2}</span>
                </li>
                <li className="text-sm leading-relaxed font-semibold pl-2">
                  <span className="text-white font-normal">{text.howItWorks.rule3}</span>
                </li>
              </ol>
            </div>
          </div>
        )}

        {/* Section: COMMANDS */}
        {activeSection === "commands" && (
          <div className="space-y-6">
            <div className="flex items-center gap-3 text-[#a3ab72]">
              <Terminal className="w-8 h-8" />
              <h1 className="text-3xl font-extrabold tracking-tight">{text.commands.title}</h1>
            </div>
            <p className="text-white/80 leading-relaxed font-medium">{text.commands.intro}</p>

            <div className="space-y-3 pt-4">
              {[
                { name: "/setup", desc: text.commands.cSetup },
                { name: "/add-an-event", desc: text.commands.cAddEvent },
                { name: "/help", desc: text.commands.cHelp },
                { name: "/info", desc: text.commands.cInfo },
                { name: "/ping", desc: text.commands.cPing },
                { name: "/invite", desc: text.commands.cInvite },
                { name: "/support", desc: text.commands.cSupport },
              ].map((cmd) => (
                <div key={cmd.name} className="bg-[#3a3d42] border border-white/5 rounded-xl p-4 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between">
                  <div className="flex items-center justify-between w-full sm:w-auto gap-4">
                    <code className="font-mono text-sm font-extrabold text-white bg-[#484c52] px-2.5 py-1 rounded-md tracking-wider shrink-0">{cmd.name}</code>
                    <button
                      onClick={() => copyToClipboard(cmd.name)}
                      className="sm:hidden bg-[#2f3136] hover:bg-[#8c935d] text-white p-1.5 rounded transition-colors"
                      title="Copy command"
                    >
                      {copiedText === cmd.name ? <Check className="w-3.5 h-3.5 text-green-400" /> : <Copy className="w-3.5 h-3.5" />}
                    </button>
                  </div>
                  <p className="text-sm text-white/80 font-medium sm:text-right flex-1 sm:pl-8">{cmd.desc}</p>
                  <button
                    onClick={() => copyToClipboard(cmd.name)}
                    className="hidden sm:block bg-[#2f3136] hover:bg-[#8c935d] text-white p-2 rounded-lg transition-colors focus:outline-none"
                    title="Copy command"
                  >
                    {copiedText === cmd.name ? <Check className="w-4 h-4 text-green-400" /> : <Copy className="w-4 h-4" />}
                  </button>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Section: EVENTS */}
        {activeSection === "events" && (
          <div className="space-y-6">
            <div className="flex items-center gap-3 text-[#a3ab72]">
              <Calendar className="w-8 h-8" />
              <h1 className="text-3xl font-extrabold tracking-tight">{text.events.title}</h1>
            </div>
            <p className="text-white/80 leading-relaxed font-medium">{text.events.intro}</p>

            {/* Warning banner */}
            <div className="bg-[#2c1a1a] border-l-4 border-[#f04747] p-5 rounded-r-xl space-y-2 shadow-lg shadow-black/10">
              <div className="flex items-center gap-2 text-[#ff6b6b]">
                <AlertTriangle className="w-5 h-5" />
                <h3 className="font-extrabold tracking-wide uppercase">{text.events.warningTitle}</h3>
              </div>
              <p className="text-sm text-white/90 leading-relaxed font-medium">
                {text.events.warningDesc}
              </p>
            </div>

            {/* inner event tabs */}
            <div className="grid grid-cols-2 lg:grid-cols-4 gap-4 pt-4">
              {(["logo", "name", "banner", "invite"] as EventTab[]).map((tab) => (
                <button
                  key={tab}
                  onClick={() => setActiveEventTab(tab)}
                  className={`p-4 rounded-xl text-left border transition-all duration-300 focus:outline-none ${
                    activeEventTab === tab
                      ? "bg-[#8c935d]/15 border-[#a3ab72] shadow-md shadow-black/15"
                      : "bg-[#3a3d42]/40 border-transparent hover:border-[#8c935d]/30"
                  }`}
                >
                  <h4 className={`font-bold text-sm mb-1 ${activeEventTab === tab ? "text-[#a3ab72]" : "text-white/90"}`}>
                    {text.events.tabs[tab].title}
                  </h4>
                  <p className="text-xs text-white/50 leading-relaxed font-medium line-clamp-2">
                    {text.events.tabs[tab].short}
                  </p>
                </button>
              ))}
            </div>

            {/* Inner event tab contents */}
            <div className="bg-[#2f3136]/50 border border-white/5 rounded-2xl p-6 space-y-6 mt-6 animate-fadeIn">
              <h3 className="text-lg font-bold text-[#a3ab72] border-b border-white/10 pb-2">
                {text.events.tabs[activeEventTab].h}
              </h3>
              
              <ol className="space-y-4 list-decimal list-inside text-white/80">
                <li className="text-sm leading-relaxed font-semibold pl-1">
                  <span className="text-white font-normal pl-2">{text.events.tabs[activeEventTab].step1}</span>
                </li>
                {text.events.tabs[activeEventTab].step2 && (
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.events.tabs[activeEventTab].step2}</span>
                  </li>
                )}
                <li className="text-sm leading-relaxed font-semibold pl-1">
                  <span className="text-white font-normal pl-2">{text.events.tabs[activeEventTab].step3}</span>
                </li>
                {text.events.tabs[activeEventTab].step4 && (
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.events.tabs[activeEventTab].step4}</span>
                  </li>
                )}
              </ol>
            </div>
          </div>
        )}

        {/* Section: LINKS */}
        {activeSection === "links" && (
          <div className="space-y-6">
            <div className="flex items-center gap-3 text-[#a3ab72]">
              <LinkIcon className="w-8 h-8" />
              <h1 className="text-3xl font-extrabold tracking-tight">{text.links.title}</h1>
            </div>
            <p className="text-white/80 leading-relaxed font-medium">{text.links.intro}</p>
            <p className="text-white/70 text-sm font-medium">{text.links.methodTitle}</p>

            {/* Inner sub-tabs */}
            <div className="flex gap-2 border-b border-white/10 pb-4">
              <button
                onClick={() => setActiveImageMethod("github")}
                className={`px-4 py-2 text-sm font-bold rounded-lg transition-colors focus:outline-none ${
                  activeImageMethod === "github"
                    ? "bg-[#8c935d] text-white"
                    : "bg-[#3a3d42] text-white/60 hover:text-white"
                }`}
              >
                {text.links.github.title}
              </button>
              <button
                onClick={() => setActiveImageMethod("imgbb")}
                className={`px-4 py-2 text-sm font-bold rounded-lg transition-colors focus:outline-none ${
                  activeImageMethod === "imgbb"
                    ? "bg-[#8c935d] text-white"
                    : "bg-[#3a3d42] text-white/60 hover:text-white"
                }`}
              >
                {text.links.imgbb.title}
              </button>
            </div>

            {/* Inner sub-tab contents */}
            {activeImageMethod === "github" ? (
              <div className="space-y-6 pt-2 animate-fadeIn">
                <h3 className="text-lg font-bold text-[#a3ab72]">{text.links.github.h}</h3>
                
                <ol className="space-y-4 list-decimal list-inside text-white/80">
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.github.step1}</span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">
                      {text.links.github.step2}
                    </span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.github.step3}</span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.github.step4}</span>
                  </li>
                </ol>

                {/* Helper Tip Box */}
                <div className="bg-[#3a3d42]/60 border border-[#8c935d]/30 p-5 rounded-2xl space-y-3">
                  <div className="flex items-center gap-2 text-[#a3ab72]">
                    <Disc className="w-5 h-5 text-[#a3ab72] animate-pulse" />
                    <h4 className="font-bold text-sm tracking-wide">{text.links.github.tipTitle}</h4>
                  </div>
                  <p className="text-xs text-white/80 leading-relaxed font-medium">
                    {text.links.github.tipDesc}
                  </p>
                  <div className="bg-[#2f3136] p-3 rounded-xl flex items-center justify-between gap-3 border border-white/5 font-mono text-[11px] font-bold text-white tracking-wide select-all overflow-x-auto">
                    <span>{text.links.github.tipExample1}</span>
                  </div>
                  <p className="text-xs text-white/80 leading-relaxed font-medium">
                    {text.links.github.tipDesc2}
                  </p>
                  <div className="bg-[#2f3136] p-3 rounded-xl flex items-center justify-between gap-3 border border-white/5 font-mono text-[11px] font-bold text-white tracking-wide select-all overflow-x-auto">
                    <span>{text.links.github.tipExample2}</span>
                  </div>
                </div>
              </div>
            ) : (
              <div className="space-y-6 pt-2 animate-fadeIn">
                <h3 className="text-lg font-bold text-[#a3ab72]">{text.links.imgbb.h}</h3>
                
                <ol className="space-y-4 list-decimal list-inside text-white/80">
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.imgbb.step1}</span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.imgbb.step2}</span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.imgbb.step3}</span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.imgbb.step4}</span>
                  </li>
                  <li className="text-sm leading-relaxed font-semibold pl-1">
                    <span className="text-white font-normal pl-2">{text.links.imgbb.step5}</span>
                  </li>
                </ol>
              </div>
            )}
          </div>
        )}
      </main>
    </div>
  );
}
